<Window x:Class="FFFMPEG_UI_2._0.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FFFMPEG_UI_2._0"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="520"
        MinHeight="730"
        Width="880"
        MinWidth="760"
        Background="#F6F7F8">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="Black"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="Black"/>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"/>
                                <TextBlock Text="{Binding Path=(local:TextBoxHelper.Placeholder), RelativeSource={RelativeSource TemplatedParent}}"
                                           Foreground="Gray"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"
                                           x:Name="Placeholder"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Grid.Row="0" Grid.Column="0" Header="Settings">
            <Button HorizontalAlignment="Stretch"
                    Style="{StaticResource FlatButtonStyle}"
                    Content="{Binding ShowFullPathButtonText}"
                    Command="{Binding ToggleShowFullPathCommand}"/>
        </GroupBox>

        <GroupBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Header="Script Execution">
            <StackPanel>
                <ComboBox Style="{StaticResource FlatComboBoxStyle}">
                    <ComboBoxItem Content="Select Script" IsSelected="True"/>
                </ComboBox>
                <Button Content="Execute Script"
                        Style="{StaticResource FlatButtonStyle}"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="0" Header="Codec Selection">
            <UniformGrid Columns="2">
                <ComboBox Style="{StaticResource FlatComboBoxStyle}"
                          MaxWidth="200"
                          ItemsSource="{Binding VideoCodecOptions}"
                          SelectedItem="{Binding SelectedVideoCodec, UpdateSourceTrigger=PropertyChanged}"/>
                <ComboBox Style="{StaticResource FlatComboBoxStyle}"
                          MaxWidth="200"
                          ItemsSource="{Binding AudioCodecOptions}"
                          SelectedItem="{Binding SelectedAudioCodec, UpdateSourceTrigger=PropertyChanged}"/>
            </UniformGrid>
        </GroupBox>

        <GroupBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Header="Input">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Left"
                        MinWidth="220"
                        Style="{StaticResource FlatButtonStyle}"
                        Content="{Binding InputFileButtonText}"
                        Command="{Binding SelectInputFileCommand}"/>
                <TextBox Text="{Binding InputFileDisplayPath, Mode=OneWay}"
                         local:TextBoxHelper.Placeholder="Input file path"
                         IsReadOnly="True"/>
            </DockPanel>
        </GroupBox>

        <GroupBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Header="Output">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Left"
                        MinWidth="220"
                        Style="{StaticResource FlatButtonStyle}"
                        Content="{Binding OutputPathButtonText}"
                        Command="{Binding SelectOutputDirectoryCommand}"/>
                <TextBox DockPanel.Dock="Left"
                         Width="280"
                         IsReadOnly="True"
                         Text="{Binding OutputDirectoryDisplayPath, Mode=OneWay}"
                         local:TextBoxHelper.Placeholder="Output directory path"/>
                <TextBox Text="{Binding OutputFileName, UpdateSourceTrigger=PropertyChanged}"
                         local:TextBoxHelper.Placeholder="Output file name"/>
            </DockPanel>
        </GroupBox>

        <GroupBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Header="Final Execution">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Bottom"
                        Style="{StaticResource FlatButtonStyle}"
                        HorizontalAlignment="Right"
                        MinWidth="300"
                        Content="Execute Command"
                        Command="{Binding ExecuteFfmpegCommandCommand}"/>

                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <Label DockPanel.Dock="Left" Content="Final command"/>
                        <Button DockPanel.Dock="Right"
                                MinHeight="28"
                                MinWidth="92"
                                Padding="10,2"
                                Content="{Binding CommandEditorToggleButtonText}"
                                Command="{Binding ToggleCommandEditorCommand}"/>
                    </DockPanel>

                    <TextBox Text="{Binding FfmpegCommand, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="{Binding IsExecuting, Mode=OneWay}"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             local:TextBoxHelper.Placeholder="Введите команду ffmpeg...">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Setter Property="Height" Value="40"/>
                                <Setter Property="TextWrapping" Value="NoWrap"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCommandEditorExpanded}" Value="True">
                                        <Setter Property="Height" Value="280"/>
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                        <Setter Property="VerticalContentAlignment" Value="Top"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCommandEditorExpanded}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <ProgressBar Margin="4,8,4,4"
                                     Height="8"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding ExecutionProgress, Mode=OneWay}"/>
                        <TextBlock Margin="4,0,4,0"
                                   Text="{Binding ExecutionProgressText}"/>
                        <TextBlock Margin="4,4,4,0"
                                   Text="{Binding ExecutionStatus}"/>
                        <TextBox MinHeight="20"
                                 Margin="4"
                                 VerticalContentAlignment="Top"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding ExecutionOutput, Mode=OneWay}"
                                 local:TextBoxHelper.Placeholder="ffmpeg output and errors"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </GroupBox>
    </Grid>
</Window>
